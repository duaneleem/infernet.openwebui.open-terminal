# infernet.openwebui.open-terminal — production stack
#
# Local workflow: copy this file to `.env` in this directory, then fill in values.
#   cp template.env .env
# In CI/Kubernetes, inject the same variable names via secrets—do not commit real values.
# This `template.env` is safe to commit; never commit `techops/production/.env`.

# -----------------------------------------------------------------------------
# Open Terminal — https://github.com/open-webui/open-terminal
# Required: server refuses to start without an API key (v0.11.30+).
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
OPEN_TERMINAL_API_KEY=

# Multi-user: per Open WebUI user Linux account + isolated home (full image only).
# Upstream warns this is for small trusted groups—not hard tenant isolation.
OPEN_TERMINAL_MULTI_USER=true

# Optional: session working-directory TTL in seconds (default 604800 = 7 days)
# OPEN_TERMINAL_SESSION_CWD_TTL=604800
